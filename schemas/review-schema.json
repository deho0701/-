{
  "name": "shorts_review",
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "approved": { "type": "boolean" },
      "overall_score": { "type": "integer", "minimum": 0, "maximum": 100 },
      "critical_issues": {
        "type": "array",
        "items": { "type": "string" }
      },
      "revision_tasks": {
        "type": "array",
        "items": { "type": "string" }
      },
      "fact_risks": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "claim": { "type": "string" },
            "risk_level": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "reason": { "type": "string" },
            "fix": { "type": "string" }
          },
          "required": ["claim", "risk_level", "reason", "fix"]
        }
      },
      "style_notes": {
        "type": "array",
        "items": { "type": "string" }
      },
      "suggested_hook_fix": { "type": "string" },
      "suggested_title_fix": { "type": "string" },
      "summary": { "type": "string" }
    },
    "required": [
      "approved",
      "overall_score",
      "critical_issues",
      "revision_tasks",
      "fact_risks",
      "style_notes",
      "suggested_hook_fix",
      "suggested_title_fix",
      "summary"
    ]
  }
}
